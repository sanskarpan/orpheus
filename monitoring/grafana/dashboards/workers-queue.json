{
  "annotations": { "list": [ { "builtIn": 1, "datasource": { "type": "grafana", "uid": "-- Grafana --" }, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard" } ] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["orpheus", "workers", "queue"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
        "definition": "label_values(orpheus_jobs_processed_total, processor)",
        "hide": 0,
        "includeAll": true,
        "label": "processor",
        "multi": true,
        "name": "processor",
        "options": [],
        "query": { "query": "label_values(orpheus_jobs_processed_total, processor)", "refId": "A" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Orpheus — Workers & Queue",
  "uid": "orpheus-workers-queue",
  "version": 1,
  "panels": [
    {
      "title": "Jobs submitted vs processed (job/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_jobs_submitted_total[$__rate_interval]))",
          "legendFormat": "submitted",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_jobs_processed_total[$__rate_interval]))",
          "legendFormat": "processed",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Backlog growth rate (submitted - processed, job/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_jobs_submitted_total[$__rate_interval])) - sum(rate(orpheus_jobs_processed_total[$__rate_interval]))",
          "legendFormat": "net intake",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Jobs submitted by processor (job/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (processor) (rate(orpheus_jobs_submitted_total{processor=~\"$processor\"}[$__rate_interval]))",
          "legendFormat": "{{processor}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Processed by status (completed/failed, job/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (status) (rate(orpheus_jobs_processed_total{processor=~\"$processor\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Job success ratio (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_jobs_processed_total{status=\"completed\"}[$__rate_interval])) / clamp_min(sum(rate(orpheus_jobs_processed_total[$__rate_interval])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JetStream ack/nak rate (msg/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 16, "x": 8, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (result) (rate(orpheus_jetstream_messages_total[$__rate_interval]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Worker processing p95 by processor (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, processor) (rate(orpheus_job_processing_duration_seconds_bucket{processor=~\"$processor\"}[$__rate_interval])))",
          "legendFormat": "{{processor}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "S3 operations by result (op/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (op, result) (rate(orpheus_s3_operations_total[$__rate_interval]))",
          "legendFormat": "{{op}} {{result}}",
          "refId": "A"
        }
      ]
    }
  ]
}
