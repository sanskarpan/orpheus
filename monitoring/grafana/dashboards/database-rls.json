  "timezone": "",
  "title": "Orpheus — Database & RLS",
  "uid": "orpheus-database-rls",
  "version": 1,
  "panels": [
    {
      "title": "RLS denials (denials/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.5 } ] }
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (table) (rate(orpheus_rls_denials_total{table=~\"$table\"}[$__rate_interval]))",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RLS denials total (window)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 100 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(increase(orpheus_rls_denials_total[$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "RLS denials by table (top offenders)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "topk(10, sum by (table) (increase(orpheus_rls_denials_total[$__range])))",
          "legendFormat": "{{table}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Postgres connection pool — Go DB stats",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "description": "Connection pool metrics exported by the Go sql/pgx collectors (go_sql_*). Watch open vs max: exhaustion shows up as blocked/waiting climbing toward the ceiling.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(go_sql_open_connections{job=\"orpheus-api\"}) or sum(pgxpool_acquired_conns{job=\"orpheus-api\"})",
          "legendFormat": "open/acquired",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(go_sql_max_open_connections{job=\"orpheus-api\"}) or sum(pgxpool_max_conns{job=\"orpheus-api\"})",
          "legendFormat": "max",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(go_sql_blocked_queries{job=\"orpheus-api\"}) or sum(pgxpool_empty_acquire_total{job=\"orpheus-api\"})",
          "legendFormat": "blocked/waiting",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Outbox publish latency by event type (p95, s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "description": "The outbox is the DB->NATS bridge. Rising publish latency often traces back to DB or NATS pressure.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, event_type) (rate(orpheus_outbox_publish_duration_seconds_bucket[$__rate_interval])))",
          "legendFormat": "{{event_type}}",
          "refId": "A"
        }
      ]
    }
  ]
}
