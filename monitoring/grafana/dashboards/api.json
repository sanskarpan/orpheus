  "tags": ["orpheus", "api"],
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
        "definition": "label_values(orpheus_http_requests_total, route)",
        "hide": 0,
        "includeAll": true,
        "label": "route",
        "multi": true,
        "name": "route",
        "options": [],
        "query": { "query": "label_values(orpheus_http_requests_total, route)", "refId": "A" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Orpheus — API",
  "uid": "orpheus-api",
  "version": 1,
  "panels": [
    {
      "title": "Request rate by route (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (route) (rate(orpheus_http_requests_total{route=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error rate (4xx / 5xx, req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_http_requests_total{route=~\"$route\", status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_http_requests_total{route=~\"$route\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx",
          "refId": "B"
        }
      ]
    },
    {
      "title": "5xx error ratio (%)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.001 }, { "color": "red", "value": 0.02 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_http_requests_total{status=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(orpheus_http_requests_total[$__rate_interval])), 1e-9)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Availability (non-5xx, 30d rolling)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.995 }, { "color": "green", "value": 0.999 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "1 - (sum(rate(orpheus_http_requests_total{status=~\"5..\"}[30d])) / clamp_min(sum(rate(orpheus_http_requests_total[30d])), 1e-9))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total request rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum(rate(orpheus_http_requests_total[$__rate_interval]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "API target up",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } } ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "max(up{job=\"orpheus-api\"})",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(orpheus_http_request_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(orpheus_http_request_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(orpheus_http_request_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "title": "p99 latency by route (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(orpheus_http_request_duration_seconds_bucket{route=~\"$route\"}[$__rate_interval])))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Requests by status class (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "bars", "fillOpacity": 40, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "orpheus-prometheus" },
          "expr": "sum by (status) (rate(orpheus_http_requests_total{route=~\"$route\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    }
  ]
}
